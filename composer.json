{
    "name": "hypejunction/user_settings",
    "type": "elgg-plugin",
    "description": "Improved settings pages for Elgg",
    "homepage": "https://github.com/hypeJunction/Elgg-user_settings",
    "keywords": [
        "elgg",
        "plugin",
        "notifications",
        "preferences"
    ],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Ismayil Khayredinov",
            "email": "ismayil.khayredinov@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "elgg/elgg": "~7.0.0",
        "composer/installers": "^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "extra": {
        "elgg-plugin": {
            "id": "user_settings"
        }
    }
}
